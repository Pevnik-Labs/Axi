{
  "grammars": [
    {
      "name": "axi",
      "camelcase": "Axi",
      "scope": "source.axi",
      "path": ".",
      "file-types": [
        "axi"
      ],
      "content-regex": null,
      "highlights": "queries/highlights.scm",
      "injection-regex": "^axi$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "Apache-2.0",
    "description": "Axi grammar for tree-sitter",
    "authors": [
      {
        "name": "Mateusz Pyzik"
      }
    ],
    "links": {
      "repository": "https://github.com/Pevnik-Labs/Axi"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}